function JackalUI.CreateToggle(config)
    config = config or {}
    local parent = config.Parent
    local name = config.Name or "Toggle"
    local callback = config.Function or function() end
    local default = config.Default or false
    local hoverText = config.HoverText
    
    local container = CreateInstance("Frame", {
        Size = UDim2.new(1, 0, 0, 35),
        BackgroundTransparency = 1,
        Parent = parent
    })
    
    local label = CreateInstance("TextLabel", {
        Size = UDim2.new(1, -50, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Color3.fromRGB(162, 162, 162),
        TextSize = 15,
        Font = Enum.Font.SourceSans,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = container
    })
    
    local toggleFrame = CreateInstance("Frame", {
        Name = "ToggleFrame1",
        Size = UDim2.new(0, 36, 0, 16),
        Position = UDim2.new(1, -46, 0, 9),
        BackgroundColor3 = Color3.fromRGB(60, 60, 60),
        BorderSizePixel = 0,
        Parent = container
    })
    
    CreateInstance("UICorner", {CornerRadius = UDim.new(1, 0), Parent = toggleFrame})
    
    local circle = CreateInstance("Frame", {
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new(0, 1, 0, 1),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        Parent = toggleFrame
    })
    
    CreateInstance("UICorner", {CornerRadius = UDim.new(1, 0), Parent = circle})
    
    local enabled = default
    
    if enabled then
        toggleFrame.BackgroundColor3 = GetRainbowColor(0)
        circle.Position = UDim2.new(0, 21, 0, 1)
    end
    
    local function updateToggle()
        if enabled then
            CreateTween(toggleFrame, {BackgroundColor3 = GetRainbowColor(0)}, 0.2):Play()
            CreateTween(circle, {Position = UDim2.new(0, 21, 0, 1)}, 0.2):Play()
        else
            CreateTween(toggleFrame, {BackgroundColor3 = Color3.fromRGB(60, 60, 60)}, 0.2):Play()
            CreateTween(circle, {Position = UDim2.new(0, 1, 0, 1)}, 0.2):Play()
        end
        callback(enabled)
    end
    
    container.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            enabled = not enabled
            updateToggle()
        end
    end)
    
    if hoverText and ToggleTooltips then
        local tooltip = nil
        container.MouseEnter:Connect(function()
            tooltip = CreateInstance("TextLabel", {
                Size = UDim2.new(0, GetTextSize(hoverText, 14).X + 20, 0, 30),
                Position = UDim2.new(0, container.AbsolutePosition.X + 50, 0, container.AbsolutePosition.Y + 35),
                BackgroundColor3 = Color3.fromRGB(37, 37, 37),
                Text = hoverText,
                TextColor3 = Color3.fromRGB(201, 201, 201),
                TextSize = 14,
                Font = Enum.Font.SourceSans,
                Parent = MainGui.ScaledGui.ClickGui
            })
            CreateInstance("UICorner", {CornerRadius = UDim.new(0, 4), Parent = tooltip})
        end)
        container.MouseLeave:Connect(function()
            if tooltip then
                tooltip:Destroy()
                tooltip = nil
            end
        end)
    end
    
    local api = {
        Object = container,
        Name = name,
        Type = "Toggle",
        Enabled = enabled,
        Toggle = function(state)
            enabled = state
            updateToggle()
        end
    }
    
    return api
end

function JackalUI.CreateSlider(config)
    config = config or {}
    local parent = config.Parent
    local name = config.Name or "Slider"
    local min = config.Min or 0
    local max = config.Max or 100
    local default = config.Default or min
    local callback = config.Function or function() end
    
    local container = CreateInstance("Frame", {
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundTransparency = 1,
        Parent = parent
    })
    
    local label = CreateInstance("TextLabel", {
        Size = UDim2.new(1, -60, 0, 20),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Color3.fromRGB(162, 162, 162),
        TextSize = 15,
        Font = Enum.Font.SourceSans,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = container
    })
    
    local valueLabel = CreateInstance("TextLabel", {
        Size = UDim2.new(0, 50, 0, 20),
        Position = UDim2.new(1, -55, 0, 0),
        BackgroundTransparency = 1,
        Text = tostring(default),
        TextColor3 = Color3.fromRGB(201, 201, 201),
        TextSize = 15,
        Font = Enum.Font.SourceSans,
        Parent = container
    })
    
    local sliderBg = CreateInstance("Frame", {
        Name = "Slider",
        Size = UDim2.new(1, -20, 0, 6),
        Position = UDim2.new(0, 10, 0, 30),
        BackgroundColor3 = Color3.fromRGB(60, 60, 60),
        BorderSizePixel = 0,
        Parent = container
    })
    
    CreateInstance("UICorner", {CornerRadius = UDim.new(1, 0), Parent = sliderBg})
    
    local fill = CreateInstance("Frame", {
        Name = "FillSlider",
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = GetRainbowColor(0),
        BorderSizePixel = 0,
        Parent = sliderBg
    })
    
    CreateInstance("UICorner", {CornerRadius = UDim.new(1, 0), Parent = fill})
    
    local button = CreateInstance("ImageButton", {
        Name = "ButtonSlider",
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new((default - min) / (max - min), -6, 0.5, -6),
        BackgroundTransparency = 1,
        Image = "rbxassetid://8992235157",
        ImageColor3 = GetRainbowColor(0),
        Parent = sliderBg
    })
    
    local dragging = false
    local currentValue = default
    
    local function updateSlider(input)
        local pos = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        local value = math.floor(min + (pos * (max - min)))
        currentValue = value
        valueLabel.Text = tostring(value)
        fill.Size = UDim2.new(pos, 0, 1, 0)
        button.Position = UDim2.new(pos, -6, 0.5, -6)
        callback(value)
    end
    
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)
    
    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateSlider(input)
            dragging = true
        end
    end)
    
