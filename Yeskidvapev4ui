function JackalUI.UpdateUI()
    local mainRainbowSat = RainbowEnabled and GetVapeSaturation(CurrentTheme.Hue) or CurrentTheme.Sat
    local mainColor = Color3.fromHSV(CurrentTheme.Hue, mainRainbowSat, RainbowEnabled and 1 or CurrentTheme.Val)
    
    if MainGui then
        local mainWin = MainGui.ScaledGui.ClickGui:FindFirstChild("MainWindow")
        if mainWin then
            local logo1 = mainWin:FindFirstChild("Logo1", true)
            if logo1 then
                logo1.TextColor3 = mainColor
            end
        end
    end
    
    for i, v in pairs(ObjectsThatCanBeSaved) do
        if v.Type == "Button" and v.Enabled then
            local btnText = v.Object:FindFirstChild("ButtonText")
            if btnText then
                btnText.TextColor3 = mainColor
            end
            local btnIcon = v.Object:FindFirstChild("ButtonIcon")
            if btnIcon then
                btnIcon.ImageColor3 = mainColor
            end
        elseif v.Type == "Toggle" and v.Enabled then
            local toggleFrame = v.Object:FindFirstChild("ToggleFrame1")
            if toggleFrame then
                toggleFrame.BackgroundColor3 = mainColor
            end
        elseif v.Type == "Slider" then
            local slider = v.Object:FindFirstChild("Slider")
            if slider then
                local fill = slider:FindFirstChild("FillSlider")
                local btn = slider:FindFirstChild("ButtonSlider")
                if fill then fill.BackgroundColor3 = mainColor end
                if btn then btn.ImageColor3 = mainColor end
            end
        elseif v.Type == "CustomWindow" or v.Type == "Window" then
            if v.Object.Visible then
                local scroll = v.Object:FindFirstChild("Content", true)
                if scroll then
                    for _, child in pairs(scroll:GetDescendants()) do
                        if child:IsA("Frame") and child.Name == "ColorFrame" then
                            child.BackgroundColor3 = mainColor
                        end
                    end
                end
            end
        end
    end
end

function JackalUI.ToggleGUI()
    local clickGui = MainGui and MainGui.ScaledGui and MainGui.ScaledGui.ClickGui
    if clickGui then
        clickGui.Visible = not clickGui.Visible
        MainBlur.Size = clickGui.Visible and 25 or 0
        RunService:SetRobloxGuiFocused(clickGui.Visible)
    end
end

function JackalUI.SelfDestruct()
    UIInjected = false
    if MainGui then
        MainGui:Destroy()
    end
    if MainBlur then
        MainBlur:Destroy()
    end
    RunService:SetRobloxGuiFocused(false)
    ObjectsThatCanBeSaved = {}
end

local function StartRainbowLoop()
    task.spawn(function()
        while UIInjected do
            if RainbowEnabled then
                CurrentTheme.Hue = (CurrentTheme.Hue + (RainbowSpeed / 100)) % 1
                JackalUI.UpdateUI()
            end
            task.wait(0.05)
        end
    end)
end

