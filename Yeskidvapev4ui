        local iconImg = CreateInstance("ImageLabel", {
            Name = "ButtonIcon",
            Size = UDim2.new(0, iconSize, 0, iconSize),
            Position = UDim2.new(0, 10, 0, (32 - iconSize) / 2),
            BackgroundTransparency = 1,
            Image = icon,
            ImageColor3 = Color3.fromRGB(162, 162, 162),
            Parent = button
        })
    end
    
    local enabled = false
    local windowObj = nil
    
    if config.Window then
        windowObj = config.Window
    end
    
    button.MouseEnter:Connect(function()
        CreateTween(button, {BackgroundColor3 = Color3.fromRGB(40, 39, 40)}, 0.1):Play()
        label.TextColor3 = Color3.fromRGB(200, 200, 200)
    end)
    
    button.MouseLeave:Connect(function()
        if not enabled then
            CreateTween(button, {BackgroundColor3 = Color3.fromRGB(26, 25, 26)}, 0.1):Play()
            label.TextColor3 = Color3.fromRGB(162, 162, 162)
        end
    end)
    
    button.MouseButton1Click:Connect(function()
        enabled = not enabled
        if enabled then
            CreateTween(button, {BackgroundColor3 = Color3.fromRGB(50, 50, 50)}, 0.1):Play()
            label.TextColor3 = GetRainbowColor(0)
            if button:FindFirstChild("ButtonIcon") then
                button.ButtonIcon.ImageColor3 = GetRainbowColor(0)
            end
        else
            CreateTween(button, {BackgroundColor3 = Color3.fromRGB(26, 25, 26)}, 0.1):Play()
            label.TextColor3 = Color3.fromRGB(162, 162, 162)
            if button:FindFirstChild("ButtonIcon") then
                button.ButtonIcon.ImageColor3 = Color3.fromRGB(162, 162, 162)
            end
        end
        
        if windowObj then
            windowObj.SetVisible(enabled)
        end
        
        callback(enabled)
    end)
    
    local api = {
        Object = button,
        Name = name,
        Type = "Button",
        Enabled = false,
        ToggleButton = function(state)
            enabled = state
            if enabled then
                button.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
                label.TextColor3 = GetRainbowColor(0)
            else
                button.BackgroundColor3 = Color3.fromRGB(26, 25, 26)
                label.TextColor3 = Color3.fromRGB(162, 162, 162)
            end
            if windowObj then
                windowObj.SetVisible(enabled)
            end
            callback(enabled)
        end
    }
    
    ObjectsThatCanBeSaved[name.."Button"] = api
    return api
end

