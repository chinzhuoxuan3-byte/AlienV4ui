                KeyBtn.Text = keyTxt
                KeyBtn.TextColor3 = ACCENT
                KeyBtn.TextSize = 11
                KeyBtn.ZIndex = 8
                corner(KeyBtn, 3)

                KeyBtn.MouseButton1Click:Connect(function()
                    KeyBtn.Text = "..."
                    KeyBtn.TextColor3 = DIM_TEXT
                    local key = services.UserInputService.InputEnded:Wait()
                    local kn = tostring(key.KeyCode.Name)
                    if key.UserInputType ~= Enum.UserInputType.Keyboard or banned[kn] then
                        KeyBtn.Text = keyTxt
                        KeyBtn.TextColor3 = ACCENT
                        return
                    end
                    bindKey = Enum.KeyCode[kn]
                    keyTxt = shortNames[kn] or kn
                    KeyBtn.Text = keyTxt
                    KeyBtn.TextColor3 = ACCENT
                end)

                services.UserInputService.InputBegan:Connect(function(inp, gpe)
                    if gpe then return end
                    if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
                    if inp.KeyCode == bindKey then cb(bindKey.Name) end
                end)
            end

