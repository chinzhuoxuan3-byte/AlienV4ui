                local cb = callback or function() end
                local banned = {Return=true,Space=true,Tab=true,Backquote=true,CapsLock=true,Escape=true,Unknown=true}
                local shortNames = {RightControl="RCtrl",LeftControl="LCtrl",LeftShift="LShift",RightShift="RShift",Semicolon=";",Quote='"',LeftBracket="[",RightBracket="]",Equals="=",Minus="-",RightAlt="RAlt",LeftAlt="LAlt"}
