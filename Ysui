    local function animateTitleGradient()
        local ts = game:GetService("TweenService")
        local ti = TweenInfo.new(3, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
        local offset = {Offset = Vector2.new(1, 0)}
        local create = ts:Create(TitleGradient, ti, offset)
        local startingPos = Vector2.new(-1, 0)
        local list = {}
        local s, kpt = ColorSequence.new, ColorSequenceKeypoint.new
        local counter = 0
        local status = "down"
        TitleGradient.Offset = startingPos
        local function rainbowColors()
            for i = 1, 10 do
                local hue = i * 17
                table.insert(list, Color3.fromHSV(hue / 255, 0.6, 1))
            end
        end
        rainbowColors()
        TitleGradient.Color = s({kpt(0, list[#list]), kpt(0.5, list[#list - 1]), kpt(1, list[#list - 2])})
        counter = #list
        local function animate()
            create:Play()
            create.Completed:Wait()
            TitleGradient.Offset = startingPos
            TitleGradient.Rotation = 180
            if counter == #list - 1 and status == "down" then
                TitleGradient.Color = s({kpt(0, TitleGradient.Color.Keypoints[1].Value), kpt(0.5, list[#list]), kpt(1, list[1])})
                counter = 1
                status = "up"
            elseif counter == #list and status == "down" then
                TitleGradient.Color = s({kpt(0, TitleGradient.Color.Keypoints[1].Value), kpt(0.5, list[1]), kpt(1, list[2])})
                counter = 2
                status = "up"
            elseif counter <= #list - 2 and status == "down" then
                TitleGradient.Color = s({kpt(0, TitleGradient.Color.Keypoints[1].Value), kpt(0.5, list[counter + 1]), kpt(1, list[counter + 2])})
                counter = counter + 2
                status = "up"
            end
            create:Play()
            create.Completed:Wait()
            TitleGradient.Offset = startingPos
            TitleGradient.Rotation = 0
            if counter == #list - 1 and status == "up" then
                TitleGradient.Color = s({kpt(0, list[1]), kpt(0.5, list[#list]), kpt(1, TitleGradient.Color.Keypoints[3].Value)})
                counter = 1
                status = "down"
            elseif counter == #list and status == "up" then
                TitleGradient.Color = s({kpt(0, list[2]), kpt(0.5, list[1]), kpt(1, TitleGradient.Color.Keypoints[3].Value)})
                counter = 2
                status = "down"
            elseif counter <= #list - 2 and status == "up" then
                TitleGradient.Color = s({kpt(0, list[counter + 2]), kpt(0.5, list[counter + 1]), kpt(1, TitleGradient.Color.Keypoints[3].Value)})
                counter = counter + 2
                status = "down"
            end
            animate()
        end
        animate()
    end
    coroutine.wrap(animateTitleGradient)()

