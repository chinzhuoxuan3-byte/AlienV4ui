                    OptionBtn.Name = "Option_" .. option
                    OptionBtn.Parent = DropdownModule
                    OptionBtn.BackgroundColor3 = DreamSurface
                    OptionBtn.BorderSizePixel = 0
                    OptionBtn.Size = UDim2.new(0, 440, 0, 28)
                    OptionBtn.AutoButtonColor = false
                    OptionBtn.Font = Enum.Font.GothamBold
                    OptionBtn.Text = option
                    OptionBtn.TextColor3 = DreamWhite
                    OptionBtn.TextSize = 13

                    OptionCorner.CornerRadius = UDim.new(0, 6)
                    OptionCorner.Name = "OptionCorner"
                    OptionCorner.Parent = OptionBtn

                    OptionGradient.Color = ColorSequence.new {
                        ColorSequenceKeypoint.new(0.00, DreamSurface),
                        ColorSequenceKeypoint.new(1.00, DreamSurfaceLight)
                    }
                    OptionGradient.Rotation = 45
                    OptionGradient.Name = "OptionGradient"
                    OptionGradient.Parent = OptionBtn

                    OptionStroke.Color = DreamAccent
                    OptionStroke.Thickness = 0.5
                    OptionStroke.Transparency = 0.6
                    OptionStroke.Name = "OptionStroke"
                    OptionStroke.Parent = OptionBtn

                    OptionBtn.MouseEnter:Connect(function()
                        services.TweenService:Create(OptionStroke, TweenInfo.new(0.2), {Transparency = 0.2}):Play()
                        services.TweenService:Create(OptionGradient, TweenInfo.new(0.2), {Rotation = 135}):Play()
                    end)

                    OptionBtn.MouseLeave:Connect(function()
                        services.TweenService:Create(OptionStroke, TweenInfo.new(0.2), {Transparency = 0.6}):Play()
                        services.TweenService:Create(OptionGradient, TweenInfo.new(0.2), {Rotation = 45}):Play()
                    end)

                    OptionBtn.MouseButton1Click:Connect(
                        function()
                            ToggleDropVis()
                            callback(OptionBtn.Text)
                            DropdownText.Text = "   " .. text .. "｜当前：" .. OptionBtn.Text
                            DreamUI.flags[flag] = OptionBtn.Text
                        end
                    )
                end

                funcs.RemoveOption = function(self, option)
                    local opt = DropdownModule:FindFirstChild("Option_" .. option)
                    if opt then
                        opt:Destroy()
                    end
                end

                funcs.SetOptions = function(self, opts)
                    for _, v in next, DropdownModule:GetChildren() do
                        if v.Name:match("Option_") then
                            v:Destroy()
                        end
                    end
                    for _, v in next, opts do
                        funcs:AddOption(v)
                    end
                end

                funcs:SetOptions(options)
                return funcs
            end
            return section
        end
        return tab
    end
    return DreamLib
end
return DreamUI
