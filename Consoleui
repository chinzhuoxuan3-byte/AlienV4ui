                DropListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateDropSize)

                DropHeader.MouseButton1Click:Connect(function()
                    dropOpen = not dropOpen
                    DropArrow.Text = dropOpen and "▴" or "▾"
                    updateDropSize()
                end)

                local funcs = {}

                funcs.AddOption = function(self, optName)
                    local OptBtn = Instance.new("TextButton")
                    OptBtn.Name = "Opt_" .. optName
                    OptBtn.Size = UDim2.new(1, 0, 0, 26)
                    OptBtn.BackgroundColor3 = THEME.Main
                    OptBtn.BorderSizePixel = 0
