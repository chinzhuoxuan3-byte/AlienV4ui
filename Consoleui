                local Track = Instance.new("Frame")
                Track.Name = "Track"
                Track.Size = UDim2.new(1, -20, 0, 8)
                Track.Position = UDim2.new(0, 10, 1, -16)
                Track.BackgroundColor3 = THEME.Main
                Track.BorderSizePixel = 0
                Track.Parent = SliderRow

                local TrackCorner = Instance.new("UICorner")
                TrackCorner.CornerRadius = UDim.new(0, 4)
                TrackCorner.Parent = Track

                local Fill = Instance.new("Frame")
                Fill.Name = "Fill"
                Fill.Size = UDim2.new(0, 0, 1, 0)
                Fill.BackgroundColor3 = THEME.Accent
                Fill.BorderSizePixel = 0
                Fill.Parent = Track

                local FillCorner = Instance.new("UICorner")
                FillCorner.CornerRadius = UDim.new(0, 4)
                FillCorner.Parent = Fill

                local function setValue(val)
                    local clamped = math.clamp(val, minVal, maxVal)
                    local formatted
                    if precise then
                        formatted = tonumber(string.format("%.1f", clamped))
                    else
                        formatted = math.floor(clamped)
                    end
                    Library.flags[flag] = formatted
                    SliderValBox.Text = tostring(formatted)
                    local pct = (formatted - minVal) / (maxVal - minVal)
                    Fill.Size = UDim2.new(pct, 0, 1, 0)
                    callback(formatted)
                end

                local function setFromMouse()
                    local pct = math.clamp((game:GetService("Players").LocalPlayer:GetMouse().X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    setValue(minVal + (maxVal - minVal) * pct)
                end

                setValue(default)

                local draggingSlider = false
                Track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        draggingSlider = true
                        setFromMouse()
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        draggingSlider = false
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        setFromMouse()
                    end
                end)

                local boxFocused = false
                SliderValBox.Focused:Connect(function() boxFocused = true end)
                SliderValBox.FocusLost:Connect(function()
                    boxFocused = false
                    local n = tonumber(SliderValBox.Text)
                    if n then setValue(n) else setValue(Library.flags[flag]) end
                end)

                local funcs = {}
                function funcs:SetValue(v) setValue(v) end
                return funcs
            end

