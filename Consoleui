                    OptBtn.Parent = DropList

                    local OptCorner = Instance.new("UICorner")
                    OptCorner.CornerRadius = UDim.new(0, 2)
                    OptCorner.Parent = OptBtn

                    OptBtn.MouseEnter:Connect(function()
                        Tween(OptBtn, {0.1, "Sine", "Out"}, {BackgroundColor3 = THEME.Element})
                    end)
                    OptBtn.MouseLeave:Connect(function()
                        Tween(OptBtn, {0.1, "Sine", "Out"}, {BackgroundColor3 = THEME.Main})
                    end)
                    OptBtn.MouseButton1Click:Connect(function()
                        Library.flags[flag] = optName
                        DropValLbl.Text = optName
                        dropOpen = false
                        DropArrow.Text = "▾"
                        updateDropSize()
                        callback(optName)
                    end)
                end

                funcs.RemoveOption = function(self, optName)
                    local opt = DropList:FindFirstChild("Opt_" .. optName)
                    if opt then opt:Destroy() end
