                funcs.SetOptions = function(self, opts)
                    for _, v in pairs(DropList:GetChildren()) do
                        if v:IsA("TextButton") then v:Destroy() end
                    end
                    for _, v in pairs(opts) do
                        funcs:AddOption(v)
