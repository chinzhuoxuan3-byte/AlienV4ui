                KbLbl.Font = Enum.Font.GothamSemibold
                KbLbl.TextXAlignment = Enum.TextXAlignment.Left
                KbLbl.Parent = KbRow

                local KbBtn = Instance.new("TextButton")
                KbBtn.Name = "KbBtn"
                KbBtn.Size = UDim2.new(0, 70, 0, 22)
                KbBtn.Position = UDim2.new(1, -78, 0.5, -11)
                KbBtn.BackgroundColor3 = THEME.Main
                KbBtn.BorderSizePixel = 0
                KbBtn.Text = "[" .. keyTxt .. "]"
                KbBtn.TextColor3 = THEME.Text
                KbBtn.TextSize = 13
                KbBtn.Font = Enum.Font.Gotham
                KbBtn.AutoButtonColor = false
                KbBtn.Parent = KbRow

                local KbBtnCorner = Instance.new("UICorner")
                KbBtnCorner.CornerRadius = UDim.new(0, 2)
                KbBtnCorner.Parent = KbBtn

                local listening = false

                KbBtn.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening = true
                    KbBtn.Text = "..."
                    KbBtn.TextColor3 = THEME.Accent
                    local conn
                    conn = UserInputService.InputEnded:Connect(function(inp, gpe)
                        if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
                        local kn = inp.KeyCode.Name
                        if banned[kn] then
                            KbBtn.Text = "[" .. (shortNames[bindKey.Name] or bindKey.Name) .. "]"
                            KbBtn.TextColor3 = THEME.Text
                            listening = false
                            conn:Disconnect()
                            return
                        end
                        bindKey = inp.KeyCode
                        keyTxt  = shortNames[kn] or kn
                        KbBtn.Text = "[" .. keyTxt .. "]"
                        KbBtn.TextColor3 = THEME.Text
                        listening = false
                        conn:Disconnect()
                    end)
                end)

                UserInputService.InputBegan:Connect(function(inp, gpe)
                    if gpe then return end
                    if inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == bindKey then
                        task.spawn(callback, bindKey.Name)
                    end
                end)

                return KbRow
            end

